---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Card from "../components/Card.astro";
---

<BaseLayout
  title="Training"
  description="Rhiwbina Squirrels U12 training times, venue and key season dates."
>
  <PageHeader
    eyebrow="Pre-season 26/27"
    title="Training & key dates"
    lead="Where and when we train, and the dates to put in your diary."
  />
  <section class="section">
    <div class="container container-narrow flow">
      <Card title="Training">
        <ul>
          <li>Venue: <strong>Caedelyn Park (CF14 6EJ)</strong></li>
          <li>Tuesdays, <strong>7–8pm</strong></li>
          <li>Pre-season starts <strong>Tuesday 4 August 2026</strong></li>
        </ul>
      </Card>

      <Card title="Pre-season focus">
        <ul>
          <li>Strength &amp; conditioning</li>
          <li>Skills &amp; structure</li>
          <li>Understanding the new rules</li>
        </ul>
      </Card>

      <Card title="What else is coming up">
        <ul>
          <li>ION fitness session — <strong>Sat 4 July 2026</strong></li>
          <li>Green Mile team-bonding session <span class="tbc">TBC</span></li>
          <li>Surprise guest coaches <span class="tbc">TBC</span></li>
          <li>2× pre-season games arranged <span class="tbc">TBC</span></li>
          <li>New kit presentation</li>
          <li>VEO analysis session</li>
        </ul>
        <p class="muted">
          Items marked <span class="tbc">TBC</span> are provisional — dates will
          be confirmed and added to the calendar nearer the time.
        </p>
      </Card>

      <Card title="Key dates: season &amp; tour">
        <ul>
          <li><strong>26/27 season starts</strong> — Sunday 6 September 2026</li>
          <li><strong>Tour</strong> — South of France, 1–4 May 2027 🇫🇷</li>
        </ul>
        <p>
          <a class="button button--outline" href="/fixtures/"
            >Add these to your calendar</a
          >
        </p>
      </Card>
    </div>
  </section>
</BaseLayout>

<style>
  .tbc {
    display: inline-block;
    font-size: var(--step--1);
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.4;
    padding: 0 0.5em;
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    color: var(--color-accent);
  }

  .muted {
    color: var(--color-muted);
    font-size: var(--step--1);
  }
</style>
