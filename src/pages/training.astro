---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Card from "../components/Card.astro";
---

<BaseLayout
  title="Training"
  description="Rhiwbina Squirrels U12 training times, venue and key season dates."
>
  <PageHeader
    eyebrow="Pre-season 26/27"
    title="Training & key dates"
    lead="Where and when we train, and the dates to put in your diary."
  />
  <section class="section">
    <div class="container container-narrow flow">
      <Card title="Training">
        <ul>
          <li>Venue: <strong>Caedelyn Park (CF14 6EJ)</strong></li>
          <li>Tuesdays, <strong>7–8pm</strong></li>
        </ul>
      </Card>
      <Card title="Key dates">
        <ul>
          <li><strong>26/27 season starts</strong> — Sunday 6 September 2026</li>
          <li><strong>Tour</strong> — South of France, 1–4 May 2027 🇫🇷</li>
        </ul>
      </Card>
      <p class="muted">
        Full pre-season schedule, focus areas and extras are being added —
        tracked in issue #6.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .muted {
    color: var(--color-muted);
    font-size: var(--step--1);
  }
</style>
