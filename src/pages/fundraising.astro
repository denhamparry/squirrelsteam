---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Card from "../components/Card.astro";

const donateUrl = "https://shop.squirrels.team";
---

<BaseLayout
  title="Fundraising"
  description="Support the Rhiwbina Squirrels U12 — donate and sponsorship options."
>
  <PageHeader
    eyebrow="Support the team"
    title="Fundraising & sponsorship"
    lead="How we fund great rugby experiences — and how you can help."
  />
  <section class="section">
    <div class="container container-narrow flow">
      <Card title="Donate">
        <p>
          The quickest way to support the team is through our fundraising shop.
        </p>
        <p><a class="button button--donate" href={donateUrl}>Donate / Fundraise</a></p>
      </Card>
      <Card title="Sponsorship tiers">
        <ul>
          <li><strong>Platinum</strong> — £1,000</li>
          <li><strong>Black</strong> — £500</li>
          <li><strong>White</strong> — £250</li>
        </ul>
      </Card>
      <p class="muted">
        Full sponsorship benefits and fundraising activities are being added —
        tracked in issue #8.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .muted {
    color: var(--color-muted);
    font-size: var(--step--1);
  }
</style>
