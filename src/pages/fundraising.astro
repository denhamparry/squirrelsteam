---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Card from "../components/Card.astro";

const donateUrl = "https://shop.squirrels.team";
const contactEmail = "contact@squirrels.team";
const sponsorMailto = `mailto:${contactEmail}?subject=Sponsorship%20enquiry`;
---

<BaseLayout
  title="Fundraising"
  description="Support the Rhiwbina Squirrels U12 — donate, fundraising activities and sponsorship options."
>
  <PageHeader
    eyebrow="Support the team"
    title="Fundraising & sponsorship"
    lead="How we fund great rugby experiences — and how you can help."
  />
  <section class="section">
    <div class="container container-narrow flow">
      <Card title="Donate">
        <p>
          The quickest way to support the team is through our fundraising shop —
          every contribution goes towards kit, facilities, fixtures and the tour.
        </p>
        <p>
          <a class="button button--donate" href={donateUrl}>Donate / Fundraise</a>
        </p>
      </Card>

      <h2>Why we fundraise</h2>
      <p>
        We want to give every child fantastic rugby experiences — indoor training
        facilities through the winter, fixtures at Cardiff Arms Park, astro
        matches, and the end-of-season tour. Those experiences cost money.
      </p>
      <p>
        Our fundraising and sponsorship plans are designed so we're not always
        relying on parents for financial support, and so we avoid asking the same
        sponsors over and over. The more we raise together, the more we can offer
        the squad.
      </p>

      <Card title="How we fundraise">
        <ul>
          <li>
            <strong>Player sponsorship</strong> — local businesses sponsor the
            team across three tiers (see below).
          </li>
          <li>
            <strong>Annual Race Night</strong> — our flagship social and
            fundraising night, <strong>17 October</strong>.
          </li>
          <li>
            <strong>Tour weekly raffle</strong> — £5 per week, with
            <strong>100% of the proceeds coming off your tour cost</strong>. Each
            week we raffle a pair of Cardiff Rugby home-fixture tickets, kindly
            donated.
          </li>
          <li>
            <strong>More ideas</strong> <span class="tbc">TBC</span> — sponsored
            car washes, a cycle challenge, and bucket collections.
          </li>
        </ul>
        <p class="muted">
          Items marked <span class="tbc">TBC</span> are still being planned —
          dates and details will be confirmed nearer the time.
        </p>
      </Card>

      <h2>Sponsorship tiers</h2>
      <p>
        Sponsoring the Squirrels puts your business in front of a great local
        audience while supporting grass-roots community sport. Three tiers are
        available:
      </p>
      <div class="tiers">
        <Card title="Platinum">
          <p class="tier__price">£1,000</p>
          <ul>
            <li>
              Season player sponsor — the designated sponsor of your supported
              child, with a video link of the child thanking their sponsor
            </li>
            <li>Advertising on our social-media channels</li>
            <li>One Star of the Week (SOTW) headline sponsor for a designated game</li>
            <li>Tax relief for your company (sponsorship / advertising)</li>
            <li>Supporting grass-roots community sport</li>
            <li>5× free entry to our annual Race Night (with sponsored horses)</li>
            <li>Race sponsor at the Race Night, with a VIP table</li>
            <li>Headline / large company logo on the tour kit</li>
            <li>Signed and framed tour kit</li>
          </ul>
        </Card>
        <Card title="Black">
          <p class="tier__price">£500</p>
          <ul>
            <li>
              Season player sponsor — the designated sponsor of your supported
              child, with a video link of the child thanking their sponsor
            </li>
            <li>Advertising on our social-media channels</li>
            <li>One Star of the Week (SOTW) headline sponsor for a designated game</li>
            <li>Tax relief for your company (sponsorship / advertising)</li>
            <li>Supporting grass-roots community sport</li>
            <li>Free entry to our annual Race Night (with sponsored horses)</li>
            <li>Race sponsor at the Race Night, with a VIP table</li>
            <li>Small / secondary company logo on the tour kit</li>
          </ul>
        </Card>
        <Card title="White">
          <p class="tier__price">£250</p>
          <ul>
            <li>
              Season player sponsor — the designated sponsor of your supported
              child, with a video link of the child thanking their sponsor
            </li>
            <li>Advertising on our social-media channels</li>
            <li>One Star of the Week (SOTW) headline sponsor for a designated game</li>
            <li>Tax relief for your company (sponsorship / advertising)</li>
            <li>Supporting grass-roots community sport</li>
            <li>Free entry to our annual Race Night (with sponsored horses)</li>
          </ul>
        </Card>
      </div>

      <Card title="Sponsorship enquiries">
        <p>
          Interested in sponsoring the Squirrels, or want to talk through the
          options? Email us and we'll be glad to help:
        </p>
        <p>
          <a href={sponsorMailto}>{contactEmail}</a>
        </p>
      </Card>
    </div>
  </section>
</BaseLayout>

<style>
  .tiers {
    display: grid;
    gap: var(--space-m);
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }
  .tier__price {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--step-2);
    line-height: 1;
    margin-bottom: var(--space-2xs);
  }

  .tbc {
    display: inline-block;
    font-size: var(--step--1);
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.4;
    padding: 0 0.5em;
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    color: var(--color-accent);
  }

  .muted {
    color: var(--color-muted);
    font-size: var(--step--1);
  }
</style>
