---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Card from "../components/Card.astro";
import SubscribeButtons from "../components/SubscribeButtons.astro";
import FixtureItem from "../components/FixtureItem.astro";
import {
  getUpcomingFixtures,
  getPastFixtures,
  type Fixture,
} from "../lib/fixtures";

const showsOnFixturesPage = (fixture: Fixture) =>
  !(fixture.data.type === "training" && fixture.data.rrule);

const upcoming = (await getUpcomingFixtures()).filter(showsOnFixturesPage);
const past = (await getPastFixtures()).filter(showsOnFixturesPage);
---

<BaseLayout
  title="Fixtures"
  description="Upcoming Rhiwbina Squirrels U12 fixtures — subscribe to add them to your calendar."
>
  <PageHeader
    eyebrow="Season 26/27"
    title="Fixtures & calendar"
    lead="Upcoming games and events. Subscribe once and they'll keep updating in your calendar."
  />

  <section class="section">
    <div class="container container-narrow flow">
      <Card title="Subscribe to the calendar">
        <p>
          Add the fixtures to your phone or computer. They'll update
          automatically whenever the schedule changes — no need to re-add
          anything.
        </p>
        <SubscribeButtons />
        <details class="help">
          <summary>How do I subscribe on my phone?</summary>
          <div class="flow">
            <p>
              <strong>iPhone / iPad:</strong> tap <em>Apple Calendar</em> above and
              confirm — it opens the Calendar app and adds the feed.
            </p>
            <p>
              <strong>Android:</strong> tap <em>Google Calendar</em>, sign in if
              asked, then confirm <em>Add calendar</em>.
            </p>
            <p>
              Prefer to paste it yourself? Use <em>Copy feed link</em> and add it
              as a subscribed/"from URL" calendar.
            </p>
          </div>
        </details>
      </Card>

      <section class="flow" aria-labelledby="upcoming-heading">
        <h2 id="upcoming-heading">Upcoming</h2>
        {
          upcoming.length === 0 ? (
            <p class="muted">No upcoming fixtures yet — check back soon.</p>
          ) : (
            <ul class="fixtures" role="list">
              {upcoming.map((f) => (
                <FixtureItem fixture={f} />
              ))}
            </ul>
          )
        }
      </section>

      {
        past.length > 0 && (
          <details class="past">
            <summary>Past events ({past.length})</summary>
            <ul class="fixtures" role="list">
              {past.map((f) => (
                <FixtureItem fixture={f} showNotes={false} dimmed />
              ))}
            </ul>
          </details>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .muted {
    color: var(--color-muted);
    font-size: var(--step--1);
  }

  .help {
    margin-top: var(--space-s);
    font-size: var(--step--1);
  }
  .help summary,
  .past summary {
    cursor: pointer;
    font-weight: 600;
  }
  .help[open] summary,
  .past[open] summary {
    margin-bottom: var(--space-2xs);
  }

  .fixtures {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-s);
  }

  .past {
    margin-top: var(--space-l);
  }
  .past[open] {
    margin-bottom: var(--space-s);
  }
</style>
