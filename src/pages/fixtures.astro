---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Card from "../components/Card.astro";
---

<BaseLayout
  title="Fixtures"
  description="Upcoming Rhiwbina Squirrels U12 fixtures — subscribe to add them to your calendar."
>
  <PageHeader
    eyebrow="Season 26/27"
    title="Fixtures & calendar"
    lead="Upcoming games and events. Subscribe once and they'll keep updating in your calendar."
  />
  <section class="section">
    <div class="container container-narrow flow">
      <Card title="Coming soon">
        <p>
          The live fixtures list and one-tap <strong>Subscribe</strong> buttons
          (Google Calendar, Apple Calendar, Outlook) are being built.
        </p>
        <p class="muted">Tracked in issues #4 (calendar feed) and #5 (this page).</p>
      </Card>
    </div>
  </section>
</BaseLayout>

<style>
  .muted {
    color: var(--color-muted);
    font-size: var(--step--1);
  }
</style>
