---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Card from "../components/Card.astro";
import SubscribeButtons from "../components/SubscribeButtons.astro";
import {
  getUpcomingFixtures,
  getPastFixtures,
  typeLabel,
  formatWhen,
  type Fixture,
} from "../lib/fixtures";

const upcoming = await getUpcomingFixtures();
const past = await getPastFixtures();

function homeAway(f: Fixture): string | null {
  if (f.data.home === undefined) return null;
  return f.data.home ? "Home" : "Away";
}
---

<BaseLayout
  title="Fixtures"
  description="Upcoming Rhiwbina Squirrels U12 fixtures — subscribe to add them to your calendar."
>
  <PageHeader
    eyebrow="Season 26/27"
    title="Fixtures & calendar"
    lead="Upcoming games and events. Subscribe once and they'll keep updating in your calendar."
  />

  <section class="section">
    <div class="container container-narrow flow">
      <Card title="Subscribe to the calendar">
        <p>
          Add the fixtures to your phone or computer. They'll update
          automatically whenever the schedule changes — no need to re-add
          anything.
        </p>
        <SubscribeButtons />
        <details class="help">
          <summary>How do I subscribe on my phone?</summary>
          <div class="flow">
            <p>
              <strong>iPhone / iPad:</strong> tap <em>Apple Calendar</em> above and
              confirm — it opens the Calendar app and adds the feed.
            </p>
            <p>
              <strong>Android:</strong> tap <em>Google Calendar</em>, sign in if
              asked, then confirm <em>Add calendar</em>.
            </p>
            <p>
              Prefer to paste it yourself? Use <em>Copy feed link</em> and add it
              as a subscribed/"from URL" calendar.
            </p>
          </div>
        </details>
      </Card>

      <section class="flow" aria-labelledby="upcoming-heading">
        <h2 id="upcoming-heading">Upcoming</h2>
        {
          upcoming.length === 0 ? (
            <p class="muted">No upcoming fixtures yet — check back soon.</p>
          ) : (
            <ul class="fixtures" role="list">
              {upcoming.map((f) => (
                <li class="fixture">
                  <div class="fixture__meta">
                    <span class="chip">{typeLabel(f.data.type)}</span>
                    {homeAway(f) && (
                      <span class="chip chip--ghost">{homeAway(f)}</span>
                    )}
                    {f.data.rrule && (
                      <span class="chip chip--ghost" title="Repeating event">
                        ↻ Recurring
                      </span>
                    )}
                  </div>
                  <h3 class="fixture__title">
                    {f.data.title}
                    {f.data.opponent && <> vs {f.data.opponent}</>}
                  </h3>
                  <p class="fixture__when">{formatWhen(f)}</p>
                  {f.data.location && (
                    <p class="fixture__where muted">{f.data.location}</p>
                  )}
                </li>
              ))}
            </ul>
          )
        }
      </section>

      {
        past.length > 0 && (
          <details class="past">
            <summary>Past events ({past.length})</summary>
            <ul class="fixtures" role="list">
              {past.map((f) => (
                <li class="fixture fixture--past">
                  <div class="fixture__meta">
                    <span class="chip">{typeLabel(f.data.type)}</span>
                  </div>
                  <h3 class="fixture__title">
                    {f.data.title}
                    {f.data.opponent && <> vs {f.data.opponent}</>}
                  </h3>
                  <p class="fixture__when">{formatWhen(f)}</p>
                </li>
              ))}
            </ul>
          </details>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .muted {
    color: var(--color-muted);
    font-size: var(--step--1);
  }

  .help {
    margin-top: var(--space-s);
    font-size: var(--step--1);
  }
  .help summary,
  .past summary {
    cursor: pointer;
    font-weight: 600;
  }
  .help[open] summary,
  .past[open] summary {
    margin-bottom: var(--space-2xs);
  }

  .fixtures {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-s);
  }
  .fixture {
    background: var(--color-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: var(--space-m);
  }
  .fixture--past {
    opacity: 0.75;
  }
  .fixture__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3xs);
    margin-bottom: var(--space-2xs);
  }
  .fixture__title {
    margin-bottom: var(--space-3xs);
  }
  .fixture__when {
    font-weight: 600;
  }
  .fixture__where {
    margin-top: var(--space-3xs);
  }

  .chip {
    display: inline-block;
    font-size: var(--step--1);
    font-weight: 600;
    line-height: 1;
    padding: 0.35em 0.6em;
    border-radius: 999px;
    background: var(--color-black);
    color: var(--color-white);
  }
  .chip--ghost {
    background: transparent;
    color: var(--color-black);
    border: 1px solid var(--color-line-dark);
  }

  .past {
    margin-top: var(--space-l);
  }
  .past[open] {
    margin-bottom: var(--space-s);
  }
</style>
